# ---------------------------------------------------------
# BOARDROOM CONFIGURATION
# ---------------------------------------------------------
# Local port to run the server on.
PORT=8080

# Root directory for persistent data (Sqlite DB, Vector index).
STORAGE_ROOT=./data

# Maximum number of sessions to keep in the in-memory LRU cache.
MAX_SESSIONS=100

# ---------------------------------------------------------
# ACTIVE LLM PROVIDER
# ---------------------------------------------------------
# Choice of backend for the core Board of Directors.
# Available options: 'ollama', 'gemini', 'openai', 'anthropic', 'xai', 'groq', 'openrouter', 'deepseek', 'mistral', or 'fake' (for testing).
LLM_PROVIDER=ollama

# Global model selection (used by Ollama, Gemini, and Fake providers).
LLM_MODEL=gemma3:1b

# ---------------------------------------------------------
# ORCHESTRATION & PERFORMANCE
# ---------------------------------------------------------
# Maximum number of agents running LLM inferences concurrently.
# Higher values increase speed but may hit rate limits or memory constraints.
MAX_CONCURRENT_AGENTS=3

# ---------------------------------------------------------
# OLLAMA CONFIGURATION (Local/Self-Hosted)
# ---------------------------------------------------------
# To use Ollama, set LLM_PROVIDER=ollama and ensure OLLAMA_HOST is reachable.
# Recommended Models: gemma3:1b, llama3:8b, mistral
OLLAMA_HOST=http://localhost:11434

# ---------------------------------------------------------
# GEMINI CONFIGURATION (Google AI)
# ---------------------------------------------------------
# To use Gemini, set LLM_PROVIDER=gemini and provide your API Key.
# Recommended Models: gemini-1.5-flash, gemini-1.5-pro
GEMINI_API_KEY=your_gemini_api_key_here

# ---------------------------------------------------------
# OPENAI CONFIGURATION
# ---------------------------------------------------------
# To use OpenAI, set LLM_PROVIDER=openai and provide your API Key.
# Recommended Models: gpt-4o, gpt-4-turbo
OPENAI_API_KEY=your_openai_api_key_here

# ---------------------------------------------------------
# ANTHROPIC CONFIGURATION
# ---------------------------------------------------------
# To use Anthropic Claude, set LLM_PROVIDER=anthropic and provide your API Key.
# Recommended Models: claude-3-5-sonnet-latest
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ---------------------------------------------------------
# XAI CONFIGURATION
# ---------------------------------------------------------
# To use xAI Grok, set LLM_PROVIDER=xai and provide your API Key.
# Recommended Models: grok-beta
XAI_API_KEY=your_xai_api_key_here

# ---------------------------------------------------------
# GROQ CONFIGURATION
# ---------------------------------------------------------
# To use Groq, set LLM_PROVIDER=groq and provide your API Key.
# Recommended Models: llama-3.3-70b-versatile, mixtral-8x7b-32768
GROQ_API_KEY=your_groq_api_key_here

# ---------------------------------------------------------
# OPENROUTER CONFIGURATION
# ---------------------------------------------------------
# To use OpenRouter, set LLM_PROVIDER=openrouter and provide your API Key.
# Recommended Models: anthropic/claude-3.5-sonnet, deepseek/deepseek-chat
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ---------------------------------------------------------
# DEEPSEEK CONFIGURATION
# ---------------------------------------------------------
# To use DeepSeek, set LLM_PROVIDER=deepseek and provide your API Key.
# Recommended Models: deepseek-chat, deepseek-reasoner
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ---------------------------------------------------------
# MISTRAL CONFIGURATION
# ---------------------------------------------------------
# To use Mistral, set LLM_PROVIDER=mistral and provide your API Key.
# Recommended Models: mistral-large-latest, pixtral-12b
MISTRAL_API_KEY=your_mistral_api_key_here
